{
  "name": "vibe-dash",
  "version": "1.0.0",
  "description": "Local-first real-time dashboard for monitoring AI-driven development projects via MCP",
  "main": "dist/server/index.js",
  "directories": {
    "doc": "docs"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx watch server/index.ts\" \"vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build && npm run typecheck && npm run build:server",
    "build:server": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "vite build && tsx server/index.ts",
    "mcp:stdio": "tsx server/mcp/stdio.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "prepublishOnly": "npm run build"
  },
  "bin": {
    "vibe-dash": "./dist/server/mcp/stdio.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "dashboard",
    "ai-agents",
    "task-management",
    "model-context-protocol",
    "developer-tools"
  ],
  "author": "sgent",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sgent/vibe-dash.git"
  },
  "homepage": "https://github.com/sgent/vibe-dash",
  "bugs": {
    "url": "https://github.com/sgent/vibe-dash/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "better-sqlite3": "^12.8.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "focus-trap-react": "^12.0.0",
    "helmet": "^8.1.0",
    "pino": "^10.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pino-pretty": "^4.7.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-unicorn": "^60.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "jsdom": "^29.0.2",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.12",
    "tsx": "^4.22.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.2"
  }
}
