{
  "name": "vibe-dash",
  "version": "1.0.0",
  "description": "Local-first real-time dashboard for monitoring AI-driven development projects via MCP",
  "main": "server/index.ts",
  "directories": {
    "doc": "docs"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx watch server/index.ts\" \"vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "vite build && tsx server/index.ts",
    "mcp:stdio": "tsx server/mcp/stdio.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "bin": {
    "vibe-dash": "./server/mcp/stdio.ts"
  },
  "keywords": [
    "mcp",
    "dashboard",
    "ai-agents",
    "task-management",
    "model-context-protocol",
    "developer-tools"
  ],
  "author": "sgent",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sgent/vibe-dash.git"
  },
  "homepage": "https://github.com/sgent/vibe-dash",
  "bugs": {
    "url": "https://github.com/sgent/vibe-dash/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@octokit/rest": "^22.0.1",
    "better-sqlite3": "^12.8.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "focus-trap-react": "^12.0.0",
    "pino": "^10.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^14.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pino-pretty": "^4.7.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.12",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.5",
    "vitest": "^4.1.2"
  }
}
